# ============================================
# media2md-player 配置
# 复制此文件为 .env 并填入真实值
# ============================================

# --- AI API (用于文稿修正 + 导读生成) ---
API_PROVIDER=deepseek
API_KEY=your_api_key_here
API_URL=https://api.deepseek.com/v1/chat/completions
MODEL_NAME=deepseek-chat

# --- Whisper (本地转写) ---
# 如果使用本地 whisper-ctranslate2，配置以下路径
WHISPER_CTRANSLATE2_EXE=
WHISPER_MODEL_DIR=
WHISPER_LOCAL_FILES_ONLY=true

# --- FFmpeg ---
# 默认从 PATH 查找，如果不在 PATH 中请指定完整路径
FFMPEG_PATH=ffmpeg

# --- 运行目录 (可选) ---
PROCESS_DIR=process
OUTPUT_DIR=output
