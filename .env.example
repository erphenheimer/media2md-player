# ============================================
# media2md-player 配置
# 复制此文件为 .env 并填入真实值
# ============================================

# --- AI API (用于文稿修正 + 导读生成) ---
API_PROVIDER=deepseek
API_KEY=your_api_key_here
API_URL=https://api.deepseek.com/v1/chat/completions
MODEL_NAME=deepseek-chat

# --- Whisper 转写参数 ---
# 可通过 media2md config 命令或 GUI 设置面板修改
WHISPER_MODEL=medium          # 模型: tiny/base/small/medium/large
WHISPER_LANGUAGE=zh           # 语言: zh/en/ja/auto
WHISPER_DEVICE=cuda           # 设备: cuda/cpu
WHISPER_COMPUTE_TYPE=float16  # 精度: float16/int8/float32

# --- Whisper 本地路径 (可选，自动配置) ---
# 运行 media2md setup 后会自动配置以下路径
WHISPER_CTRANSLATE2_EXE=
WHISPER_MODEL_DIR=
WHISPER_LOCAL_FILES_ONLY=true

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg

# --- 运行目录 (可选) ---
PROCESS_DIR=process
OUTPUT_DIR=output
